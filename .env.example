# Stripe API Keys
# Copia este archivo como .env y reemplaza con tus claves reales

# Clave pública (Publishable key) - se expone al cliente
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx

# Backend principal para registro y otros endpoints de negocio
VITE_BACKEND_URL=http://localhost:3000

# Supabase Auth para iniciar sesion con email y contrasena
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=tu-clave-publica-supabase

# Clave privada (Secret key) - SOLO para backend/servidor
STRIPE_SECRET_KEY=sk_test_xxx

# Vite dev/preview en red local
# Por defecto `npm run dev` escuchara en 0.0.0.0 para exponer la app en la red local.
# Si quieres fijar otro host o puerto, descomenta estas lineas.
# DEV_HOST=0.0.0.0
# DEV_PORT=5173
# PREVIEW_HOST=0.0.0.0
# PREVIEW_PORT=4173
